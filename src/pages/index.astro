---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Etacom Technology | Software, AI, Data & ICT Solutions" description="Etacom Technology - Software, AI, data solutions, data center, and ICT equipment supplying & installation for hotels, enterprises and NGOs in Ethiopia.">
  <Header homeLink="#" />
  
  <main>
    <section class="hero" id="home">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <h1 class="hero-title">
          Powering Innovation with
          <span class="gradient-text">Technology & Intelligence</span>
        </h1>
        <p class="hero-desc">
          Etacom Technology delivers cutting-edge software, AI, data solutions, data center infrastructure,
          and ICT equipment supply & installation — empowering hotels, enterprises, NGOs, and government
          organizations across Ethiopia.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Start a Project</a>
          <a href="#services" class="btn btn-outline">Explore Services</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <strong>20+</strong>
            <span>Projects Delivered</span>
          </div>
          <div class="hero-stat">
            <strong>15+</strong>
            <span>Happy Clients</span>
          </div>
          <div class="hero-stat">
            <strong>100%</strong>
            <span>Client Focus</span>
          </div>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container features-grid">
        <article class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Software Development</h3>
          <p>Custom web, mobile, and enterprise software built with modern architectures and best-in-class technologies.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3>AI & Machine Learning</h3>
          <p>Intelligent solutions including predictive models, NLP, computer vision, and process automation powered by AI.</p>
        </article>
        <article class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          </div>
          <h3>Data Engineering</h3>
          <p>End-to-end data pipelines, warehousing, and analytics infrastructure to turn raw data into actionable insights.</p>
        </article>
      </div>
    </section>

    <section class="about section" id="about">
      <div class="container about-grid">
        <div class="about-image">
          <div class="about-image-main">
            <div class="about-image-overlay">
              <span class="about-year">Est. 2023</span>
              <p>Mekelle, Ethiopia</p>
            </div>
          </div>
        </div>
        <div class="about-content">
          <span class="section-tag">About Us</span>
          <h2 class="section-title">Trusted Technology Partner in Ethiopia</h2>
          <p class="about-text">
            Founded in 2023, Etacom Technology has quickly established itself as a reliable provider
            of software, AI, data, data center, and ICT solutions. With our headquarters in Mekelle
            and operations across Ethiopia, we serve hotels, enterprises, NGOs, government agencies,
            and manufacturing firms.
          </p>
          <p class="about-text">
            We combine deep technical expertise with a passion for innovation to deliver solutions that
            drive efficiency, unlock insights, and create lasting value for every client we serve.
          </p>
          <ul class="about-list">
            <li>Skilled engineers, data scientists & ICT technicians</li>
            <li>Modern technology stack & best practices</li>
            <li>End-to-end project delivery & installation</li>
            <li>Ongoing support and maintenance</li>
          </ul>
          <a href="#services" class="btn btn-primary">Our Services</a>
        </div>
      </div>
    </section>

    <section class="stats">
      <div class="container stats-grid">
        <div class="stat-item">
          <span class="stat-number" data-target="3">0</span>
          <span class="stat-label">Years Experience</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="20">0</span>
          <span class="stat-label">Projects Delivered</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="15">0</span>
          <span class="stat-label">Happy Clients</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="12">0</span>
          <span class="stat-label">Team Members</span>
        </div>
      </div>
    </section>

    <section class="services section" id="services">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Our Services</span>
          <h2 class="section-title">Comprehensive Technology Solutions</h2>
          <p class="section-desc">From software and AI to data center and ICT infrastructure, we deliver end-to-end solutions tailored to your needs.</p>
        </div>
        <div class="services-grid">
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <h3>Custom Software Development</h3>
            <p>Tailored web and enterprise applications built with modern frameworks, clean architecture, and scalable infrastructure.</p>
            <ul class="service-tags">
              <li>Web Apps</li>
              <li>Enterprise Software</li>
              <li>API Development</li>
            </ul>
            <a href="service.html?slug=custom-software-development" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <h3>AI & Machine Learning</h3>
            <p>Intelligent solutions including predictive analytics, natural language processing, and computer vision systems.</p>
            <ul class="service-tags">
              <li>Predictive Models</li>
              <li>NLP & Chatbots</li>
              <li>Computer Vision</li>
            </ul>
            <a href="service.html?slug=ai-machine-learning" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            </div>
            <h3>Data Engineering & Analytics</h3>
            <p>Robust data pipelines, warehousing solutions, and analytics dashboards that turn data into decisions.</p>
            <ul class="service-tags">
              <li>Data Pipelines</li>
              <li>Data Warehousing</li>
              <li>Analytics Dashboards</li>
            </ul>
            <a href="service.html?slug=data-engineering-analytics" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>
            </div>
            <h3>Cloud Solutions & DevOps</h3>
            <p>Cloud migration, infrastructure automation, and CI/CD pipelines for reliable and scalable deployments.</p>
            <ul class="service-tags">
              <li>Cloud Migration</li>
              <li>CI/CD Pipelines</li>
              <li>Infrastructure as Code</li>
            </ul>
            <a href="service.html?slug=cloud-solutions-devops" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
            </div>
            <h3>Mobile & Web Applications</h3>
            <p>Cross-platform mobile apps and responsive web applications designed for performance and great user experience.</p>
            <ul class="service-tags">
              <li>iOS & Android</li>
              <li>Progressive Web Apps</li>
              <li>UI/UX Design</li>
            </ul>
            <a href="service.html?slug=mobile-web-applications" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 0 1 9-9"/></svg>
            </div>
            <h3>Data Visualization & BI</h3>
            <p>Interactive dashboards and business intelligence solutions that make complex data clear and actionable.</p>
            <ul class="service-tags">
              <li>BI Dashboards</li>
              <li>Real-time Reporting</li>
              <li>Data Storytelling</li>
            </ul>
            <a href="service.html?slug=data-visualization-bi" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3>Data Center Solutions</h3>
            <p>Design, supply, and installation of data center infrastructure including servers, storage, cooling, and power systems.</p>
            <ul class="service-tags">
              <li>Server & Storage</li>
              <li>Cooling & Power</li>
              <li>Data Center Design</li>
            </ul>
            <a href="service.html?slug=data-center-solutions" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h3>Digital Transformation</h3>
            <p>Strategic consulting and technology implementation to modernize operations and drive digital growth.</p>
            <ul class="service-tags">
              <li>Strategy Consulting</li>
              <li>Legacy Modernization</li>
              <li>Tech Advisory</li>
            </ul>
            <a href="service.html?slug=digital-transformation" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
          <article class="service-card">
            <div class="service-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </div>
            <h3>ICT Equipment Supply & Installation</h3>
            <p>Supply, installation, and configuration of ICT equipment for hotels, enterprises, NGOs, and government organizations.</p>
            <ul class="service-tags">
              <li>Networking & Wi-Fi</li>
              <li>CCTV & Access Control</li>
              <li>Structured Cabling</li>
            </ul>
            <a href="service.html?slug=ict-equipment-supply-installation" class="service-card-link">Learn More <span>&rarr;</span></a>
          </article>
        </div>
      </div>
    </section>

    <section class="clients section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Trusted By</span>
          <h2 class="section-title">Our Valued Clients</h2>
          <p class="section-desc">We are proud to have served leading hotels, enterprises, NGOs, and government organizations across Ethiopia.</p>
        </div>
        <div class="clients-grid">
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><strong>Northern Star Hotel</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><strong>Libanos Hotel</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><strong>Nyala Motors</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><strong>Homeland Hotel</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a10 10 0 1 0 10 10 10 10 0 0 0-10-10z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div><strong>IOM Ethiopia</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><strong>Balloni Hotel</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg></div><strong>Genfel Hotel</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div><strong>Legasona Vehicle Mfg</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div><strong>Yarson Importer</strong></div>
          <div class="client-item"><div class="client-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20h20"/><path d="M4 20V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12"/><path d="M8 20v-4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4"/></svg></div><strong>Water Works</strong></div>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <div class="container cta-content">
        <div>
          <h2>Let's discuss your project</h2>
          <p>Tell us what you need and we'll find the right solution.</p>
        </div>
        <a href="#contact" class="btn btn-white">Get in Touch</a>
      </div>
    </section>

    <section class="contact section" id="contact">
      <div class="container contact-grid">
        <div class="contact-info">
          <span class="section-tag">Contact Us</span>
          <h2 class="section-title">Let's Start Your Digital Journey</h2>
          <p>Have a project in mind? Reach out and our team will respond within 24 hours.</p>
          <ul class="contact-list">
            <li>
              <div class="contact-list-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <strong>Email</strong>
                <a href="mailto:info@etacomtechnology.com">info@etacomtechnology.com</a>
              </div>
            </li>
            <li>
              <div class="contact-list-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <strong>Phone</strong>
                <a href="tel:+251914000001">+251-914-000-001</a>
              </div>
            </li>
            <li>
              <div class="contact-list-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <strong>Availability</strong>
                <span>Mon – Sat: 8:30 AM – 6:00 PM</span>
              </div>
            </li>
          </ul>
        </div>
        <form id="contactForm" action={`https://formspree.io/f/${import.meta.env.PUBLIC_FORMSPREE_ID}`} method="POST" class="contact-form">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" placeholder="+251..." required>
            </div>
          </div>
          <div class="form-group">
            <label for="service">Service Interested In</label>
            <select id="service" name="service" required>
              <option value="">Select a service</option>
              <option value="software">Custom Software Development</option>
              <option value="ai">AI & Machine Learning</option>
              <option value="data">Data Engineering & Analytics</option>
              <option value="cloud">Cloud Solutions & DevOps</option>
              <option value="mobile">Mobile & Web Applications</option>
              <option value="bi">Data Visualization & BI</option>
              <option value="datacenter">Data Center Solutions</option>
              <option value="ict">ICT Equipment Supply & Installation</option>
              <option value="transformation">Digital Transformation</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell us about your project..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-full">Send Message</button>
          <p class="form-note" id="formNote"></p>
        </form>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
