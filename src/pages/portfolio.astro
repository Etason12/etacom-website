---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Portfolio | Etacom Technology" description="See our work - hotel management systems, ICT infrastructure, data solutions, and software projects delivered across Ethiopia.">
  <Header homeLink="/" />

  <main>
    <section class="page-hero">
      <div class="page-hero-bg"></div>
      <div class="container page-hero-content">
        <h1 class="page-hero-title">Our Work</h1>
        <p class="page-hero-desc">Projects we've delivered for hotels, enterprises, NGOs, and government organizations</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Our Work</span>
          <h2 class="section-title">Featured Projects</h2>
        </div>
        <div class="portfolio-grid">
          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">ICT Infrastructure</span>
            </div>
            <h3>Northern Star Hotel — ICT & Smart Systems</h3>
            <p>Full ICT infrastructure deployment including network backbone, Wi-Fi, CCTV, IPTV, and PABX. Also delivered a Telegram-based chatbot for categorizing and dispatching guest orders.</p>
            <div class="portfolio-tags">
              <span>Networking</span>
              <span>CCTV</span>
              <span>IPTV</span>
              <span>PABX</span>
              <span>Telegram Bot</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">ICT Infrastructure</span>
            </div>
            <h3>Libanos Hotel — AV, Network & Safety</h3>
            <p>Complete hotel TV system, full audio-visual installation, WiFi and network infrastructure, and fire alarm detection system (FADS).</p>
            <div class="portfolio-tags">
              <span>Hotel TV</span>
              <span>Audio-Visual</span>
              <span>WiFi & Network</span>
              <span>Fire FADS</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">Security</span>
            </div>
            <h3>IOM Ethiopia — CCTV Installation</h3>
            <p>Installed and commissioned 24 CCTV cameras across both the Shire and Mekelle offices for the International Organization for Migration.</p>
            <div class="portfolio-tags">
              <span>CCTV</span>
              <span>Shire Office</span>
              <span>Mekelle Office</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">Software & Infrastructure</span>
            </div>
            <h3>Legasona Vehicle Manufacturing — LAN & ERP</h3>
            <p>Full LAN infrastructure deployment and a custom ERP system covering inventory management, point-of-sale, customer CRM, order queue, stock transfers, purchasing, expense tracking, multi-branch support, role-based access, dark mode, and full Amharic translation.</p>
            <div class="portfolio-tags">
              <span>LAN Infrastructure</span>
              <span>ERP</span>
              <span>Inventory</span>
              <span>POS</span>
              <span>CRM</span>
              <span>Amharic</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">Software Development</span>
            </div>
            <h3>Daramba Hotel — Pension Management System</h3>
            <p>Built a pension management system for tracking and managing employee pension data, contributions, and payouts.</p>
            <div class="portfolio-tags">
              <span>Pension System</span>
              <span>Web Application</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">ICT Infrastructure</span>
            </div>
            <h3>Homeland Hotel — Full ICT Setup</h3>
            <p>WiFi, CCTV, hotel TV system, time attendance and access control installation, and server setup and installation.</p>
            <div class="portfolio-tags">
              <span>WiFi</span>
              <span>CCTV</span>
              <span>Hotel TV</span>
              <span>Access Control</span>
              <span>Server</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">Security</span>
            </div>
            <h3>Nyala Motors — CCTV Surveillance</h3>
            <p>Installed 8 CCTV cameras covering both the garage and office premises for complete security coverage.</p>
            <div class="portfolio-tags">
              <span>CCTV</span>
              <span>Garage</span>
              <span>Office</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">ICT Infrastructure</span>
            </div>
            <h3>Balloni Hotel — Network & Access Systems</h3>
            <p>Hotel networking infrastructure, PBX phone system, door access installation and setup, and time attendance access control.</p>
            <div class="portfolio-tags">
              <span>Networking</span>
              <span>PBX</span>
              <span>Door Access</span>
              <span>Time Attendance</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">ICT Infrastructure</span>
            </div>
            <h3>Genfel Hotel — WiFi & Network Upgrade</h3>
            <p>Ticket-based WiFi management system, network infrastructure upgrade, router configuration, and server installation.</p>
            <div class="portfolio-tags">
              <span>WiFi Management</span>
              <span>Network Upgrade</span>
              <span>Server</span>
            </div>
          </article>

          <article class="portfolio-card">
            <div class="portfolio-card-header">
              <span class="portfolio-category">Web Development</span>
            </div>
            <h3>Yarson Importer / Water Works — Website</h3>
            <p>Designed and developed a professional website for Yarson Importer and Water Works.</p>
            <div class="portfolio-tags">
              <span>Web Design</span>
              <span>Web Development</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--neutral-50);">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Industries</span>
          <h2 class="section-title">Sectors We Serve</h2>
        </div>
        <div class="industries-grid">
          <div class="industry-item">
            <div class="industry-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 21h18M5 21V7l8-4v18M13 21V3l6 3v15"/></svg>
            </div>
            <h4>Hotels & Hospitality</h4>
            <p>PMS, IPTV, guest Wi-Fi, CCTV, structured cabling</p>
          </div>
          <div class="industry-item">
            <div class="industry-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/></svg>
            </div>
            <h4>NGOs & Development</h4>
            <p>Data analytics, dashboards, reporting systems</p>
          </div>
          <div class="industry-item">
            <div class="industry-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h4>Government</h4>
            <p>Data centers, network infrastructure, security systems</p>
          </div>
          <div class="industry-item">
            <div class="industry-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42"/></svg>
            </div>
            <h4>Manufacturing & Enterprise</h4>
            <p>ERP, networking, automation, digital transformation</p>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-banner">
      <div class="container cta-content">
        <div>
          <h2>Have a project in mind?</h2>
          <p>Tell us what you need and we'll build the right solution.</p>
        </div>
        <a href="/contact" class="btn btn-white">Start a Project</a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .page-hero {
    position: relative;
    padding: 140px 0 80px;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background: var(--dark);
  }
  .page-hero-content {
    position: relative;
    z-index: 1;
  }
  .page-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--white);
    margin-bottom: 12px;
  }
  .page-hero-desc {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.7);
    max-width: 500px;
  }
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .portfolio-card {
    background: var(--white);
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: all var(--transition);
  }
  .portfolio-card:hover {
    border-color: transparent;
    box-shadow: var(--shadow-lg);
  }
  .portfolio-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .portfolio-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary);
    background: var(--gray-100);
    padding: 4px 10px;
    border-radius: 50px;
  }
  .portfolio-year {
    font-size: 0.8125rem;
    color: var(--text-light);
  }
  .portfolio-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .portfolio-card > p {
    font-size: 0.9375rem;
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 14px;
  }
  .portfolio-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }
  .portfolio-tags span {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 3px 10px;
    background: var(--neutral-100);
    color: var(--text-light);
    border-radius: 50px;
  }
  .portfolio-result {
    font-size: 0.875rem;
    color: var(--text);
    padding-top: 14px;
    border-top: 1px solid var(--neutral-200);
  }
  .portfolio-result strong {
    color: var(--primary);
  }
  .industries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .industry-item {
    text-align: center;
    padding: 32px 20px;
    background: var(--white);
    border: 1px solid var(--neutral-200);
    border-radius: var(--radius-lg);
  }
  .industry-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gray-100);
    border-radius: 14px;
  }
  .industry-icon svg {
    width: 28px;
    height: 28px;
    color: var(--primary);
  }
  .industry-item h4 {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 8px;
  }
  .industry-item p {
    font-size: 0.8125rem;
    color: var(--text-light);
    line-height: 1.5;
  }
  @media (max-width: 768px) {
    .portfolio-grid, .industries-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
